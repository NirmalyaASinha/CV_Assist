<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="landing">
    <header class="topbar">
      <div class="logo-stack">
        <img class="logo-img" src="/assets/SASET.png" alt="SASET" />
        <img class="logo-img" src="/assets/RRU.png" alt="RRU" />
      </div>
      <nav class="nav">
        <a href="/results" class="nav-link">Results</a>
        <a href="#features" class="nav-link">Help</a>
      </nav>
      <div class="logo-spacer"></div>
    </header>

    <div class="shell">
      <main class="page landing-main">
        <section class="hero-panel">
          <div class="hero-copy">
            <p class="eyebrow">EARLY ACCESS</p>
            <h1 class="title"><%= title %></h1>
            <p class="lead"><%= subtitle %></p>
            <p class="supporting-copy">
              Upload your CV, let AI detect your domain, and instantly see matching internships,
              jobs, and resume improvements.
            </p>
            <div class="word-strip" aria-hidden="true">
              <span class="word-track">
                <span>Internships</span>
                <span>Jobs</span>
                <span>Skills</span>
                <span>Matches</span>
                <span>Feedback</span>
                <span>Domains</span>
              </span>
            </div>
          </div>

          <form class="landing-actions" id="landingForm" action="/upload" method="post" enctype="multipart/form-data">
            <label class="upload-inline">
              <input type="file" name="cv" accept=".pdf,.doc,.docx" required />
              <span>Upload CV</span>
              <span class="upload-status" id="uploadStatus" aria-live="polite" hidden>
                <span class="upload-status-dot" aria-hidden="true"></span>
                <span class="upload-status-text">File ready</span>
              </span>
            </label>
            <input class="input landing-search" type="text" name="q" placeholder="Search internships or jobs" />
            <button class="btn primary" type="submit">Search</button>
          </form>

          <p class="hint">Upload your CV to detect domain and see tailored matches.</p>
          <p class="error-banner" id="landingError" <%= errorMessage ? "" : "hidden" %>><%= errorMessage %></p>
        </section>

        <section id="features" class="features features-clean">
          <article class="feature-card">
            <div class="icon">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <rect x="4" y="4" width="16" height="16" rx="3" fill="none" stroke="currentColor" stroke-width="1.5" />
                <path d="M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Upload & Extract</h3>
            <p>We detect your domain and role preferences from the CV.</p>
          </article>
          <article class="feature-card">
            <div class="icon">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />
                <path d="M12 8v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3>Match Opportunities</h3>
            <p>Backend filters internships and companies relevant to your domain.</p>
          </article>
          <article class="feature-card">
            <div class="icon">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M6 17l4-4 3 3 5-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M5 19h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>CV Improvements</h3>
            <p>AI feedback highlights gaps and improvements to your CV.</p>
          </article>
        </section>
      </main>
    </div>
    <div class="overlay" id="processingOverlay" hidden>
      <div class="overlay-card">
        <div class="spinner"></div>
        <p class="overlay-title">Processing your CV...</p>
        <p class="overlay-message" id="processingMessage">Finding your strongest matches and preparing AI insights.</p>
      </div>
    </div>
    <script src="/app.js"></script>
  </body>
</html>
