<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Early Access</p>
        <h1><%= title %></h1>
        <p class="lead"><%= subtitle %></p>
        <div class="hero-actions">
          <a class="btn primary" href="/dashboard">Open Dashboard</a>
          <a class="btn ghost" href="#features">View Features</a>
        </div>
      </section>

      <section id="features" class="features">
        <div class="card">
          <h3>Upload & Extract</h3>
          <p>Students upload their CV, and we extract key skills and focus areas.</p>
        </div>
        <div class="card">
          <h3>Opportunity Match</h3>
          <p>Filter internships and companies based on the profile and interests.</p>
        </div>
        <div class="card">
          <h3>Improve Your CV</h3>
          <p>Guided improvements and feedback to strengthen the resume.</p>
        </div>
      </section>
    </main>
  </body>
</html>
